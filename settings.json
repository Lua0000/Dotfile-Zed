{
  "disable_ai": true,
  "enable_language_server": true,
  "icon_theme": "Warm Charmed Icons",
  "theme": "One Dark Pro Glass",
  "theme_overrides": {
    "Aura Dark": {
      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",
      "border.variant": "#000000",
      "border": "#000000",
      "title_bar.background": "#000000",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#BD9DFF",
        },
      ],
    },
  },
  "lsp": {
    "clangd": {
      "initialization_options": {
        "fallbackFlags": [
          "-IC:\\MinGW\\include",
          "-IC:\\MinGW\\lib\\gcc\\mingw32\\6.3.0\\include",
        ],
      },
    },
  },
  "ui_font_family": "DM Mono",
  "ui_font_size": 16,
  "buffer_font_family": "DM Mono",
  "buffer_font_size": 15,
  "buffer_line_height": {
    "custom": 2,
  },
  "project_panel": {
    "default_width": 440,
  },
  "buffer_font_features": {
    "calt": true,
  },
}
